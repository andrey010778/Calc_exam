<Window x:Class="Calculator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Калькулятор" 
        Height="480" Width="380"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow"
        Topmost="True"
        Background="#2C3E50"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="BaseButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#34495E"/>
        </Style>

        
        <Style x:Key="NumberButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="#ECF0F1"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#BDC3C7"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#95A5A6"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        
        <Style x:Key="OperatorButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="#E67E22"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D35400"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#A04000"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        
        <Style x:Key="FunctionButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2980B9"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#1F618D"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        
        <Style x:Key="EqualButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="#27AE60"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#229954"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#1E8449"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        
        <Menu x:Name="MainMenu" Grid.Row="0" Background="#34495E" Foreground="White" Height="25">
            <MenuItem Header="Файл">
                <MenuItem x:Name="StandardModeMenuItem" Header="Стандартный" Click="StandardMode_Click" IsCheckable="True" IsChecked="True"/>
                <MenuItem x:Name="EngineeringModeMenuItem" Header="Инженерный" Click="EngineeringMode_Click" IsCheckable="True" IsChecked="False"/>
                <Separator/>
                <MenuItem Header="Выход" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="Правка">
                <MenuItem Header="Копировать" Click="Copy_Click"/>
                <MenuItem Header="Вставить" Click="Paste_Click"/>
                <Separator/>
                <MenuItem Header="Сброс" Click="Clear_Click"/>
            </MenuItem>
            <MenuItem Header="Вид">
                <MenuItem Header="Всегда поверх окон" IsCheckable="True" IsChecked="True" Click="Topmost_Click"/>
            </MenuItem>
            <MenuItem Header="Справка">
                <MenuItem Header="Помощь" Click="Help_Click"/>
                <MenuItem Header="О программе" Click="About_Click"/>
            </MenuItem>
        </Menu>

        
        <Border Grid.Row="1" Background="#ECF0F1" BorderBrush="#34495E" BorderThickness="2" 
                CornerRadius="5" Margin="0,5,0,10" Padding="5" Height="70">
            <TextBox x:Name="Display" Text="0" IsReadOnly="True" 
                     Background="Transparent" Foreground="#2C3E50"
                     FontSize="32" FontWeight="Bold" 
                     HorizontalContentAlignment="Right" 
                     VerticalContentAlignment="Center"
                     BorderThickness="0"
                     IsHitTestVisible="False"
                     Focusable="False"/>
        </Border>

        
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel x:Name="ButtonsPanel" Margin="0,0,0,5">
               
                <UniformGrid Rows="1" Columns="5" Margin="0,2">
                    <Button Content="MC" Style="{StaticResource FunctionButtonStyle}" 
                            Tag="MC" Click="Memory_Click" ToolTip="Очистить память"/>
                    <Button Content="MR" Style="{StaticResource FunctionButtonStyle}" 
                            Tag="MR" Click="Memory_Click" ToolTip="Восстановить из памяти"/>
                    <Button Content="MS" Style="{StaticResource FunctionButtonStyle}" 
                            Tag="MS" Click="Memory_Click" ToolTip="Сохранить в память"/>
                    <Button Content="M+" Style="{StaticResource FunctionButtonStyle}" 
                            Tag="MPlus" Click="Memory_Click" ToolTip="Добавить к значению в памяти"/>
                    <Button Content="C" Style="{StaticResource FunctionButtonStyle}" 
                            Click="Clear_Click" ToolTip="Полная очистка"/>
                </UniformGrid>

                
                <UniformGrid x:Name="EngineeringRow1" Rows="1" Columns="5" Margin="0,2" Visibility="Collapsed">
                    <Button Content="xʸ" Style="{StaticResource OperatorButtonStyle}" 
                            Tag="Power" Click="Operator_Click" ToolTip="Возведение в степень"/>
                    <Button Content="√" Style="{StaticResource OperatorButtonStyle}" 
                            Tag="Sqrt" Click="Operator_Click" ToolTip="Квадратный корень"/>
                    <Button Content="∛" Style="{StaticResource OperatorButtonStyle}" 
                            Tag="CubeRoot" Click="Operator_Click" ToolTip="Кубический корень"/>
                    <Button Content="x²" Style="{StaticResource OperatorButtonStyle}" 
                            Tag="Square" Click="Operator_Click" ToolTip="Квадрат числа"/>
                    <Button Content="1/x" Style="{StaticResource OperatorButtonStyle}" 
                            Tag="Reciprocal" Click="Operator_Click" ToolTip="Обратное значение"/>
                </UniformGrid>

                
                <UniformGrid x:Name="EngineeringRow2" Rows="1" Columns="4" Margin="0,2" Visibility="Collapsed">
                    <Button Content="n!" Style="{StaticResource OperatorButtonStyle}" 
                            Tag="Factorial" Click="Operator_Click" ToolTip="Факториал числа"/>
                    <Button Content="Кв.ур." Style="{StaticResource OperatorButtonStyle}" 
                            Click="SolveQuadratic_Click" ToolTip="Решение квадратного уравнения"/>
                    <Button Content="CE" Style="{StaticResource FunctionButtonStyle}" 
                            Click="ClearEntry_Click" ToolTip="Очистить ввод"/>
                    <Button Content="⌫" Style="{StaticResource FunctionButtonStyle}" 
                            Click="Backspace_Click" ToolTip="Удалить последний символ"/>
                </UniformGrid>

                
                <UniformGrid Rows="1" Columns="5" Margin="0,2">
                    <Button Content="7" Style="{StaticResource NumberButtonStyle}" 
                            Click="Number_Click" ToolTip="7"/>
                    <Button Content="8" Style="{StaticResource NumberButtonStyle}" 
                            Click="Number_Click" ToolTip="8"/>
                    <Button Content="9" Style="{StaticResource NumberButtonStyle}" 
                            Click="Number_Click" ToolTip="9"/>
                    <Button Content="÷" Style="{StaticResource OperatorButtonStyle}" 
                            Tag="Divide" Click="Operator_Click" ToolTip="Деление"/>
                    <Button Content="C" Style="{StaticResource FunctionButtonStyle}" 
                            Click="Clear_Click" ToolTip="Полная очистка"/>
                </UniformGrid>

                
                <UniformGrid Rows="1" Columns="5" Margin="0,2">
                    <Button Content="4" Style="{StaticResource NumberButtonStyle}" 
                            Click="Number_Click" ToolTip="4"/>
                    <Button Content="5" Style="{StaticResource NumberButtonStyle}" 
                            Click="Number_Click" ToolTip="5"/>
                    <Button Content="6" Style="{StaticResource NumberButtonStyle}" 
                            Click="Number_Click" ToolTip="6"/>
                    <Button Content="×" Style="{StaticResource OperatorButtonStyle}" 
                            Tag="Multiply" Click="Operator_Click" ToolTip="Умножение"/>
                    <Button Content="±" Style="{StaticResource FunctionButtonStyle}" 
                            Click="Sign_Click" ToolTip="Смена знака"/>
                </UniformGrid>

                
                <UniformGrid Rows="1" Columns="5" Margin="0,2">
                    <Button Content="1" Style="{StaticResource NumberButtonStyle}" 
                            Click="Number_Click" ToolTip="1"/>
                    <Button Content="2" Style="{StaticResource NumberButtonStyle}" 
                            Click="Number_Click" ToolTip="2"/>
                    <Button Content="3" Style="{StaticResource NumberButtonStyle}" 
                            Click="Number_Click" ToolTip="3"/>
                    <Button Content="-" Style="{StaticResource OperatorButtonStyle}" 
                            Tag="Subtract" Click="Operator_Click" ToolTip="Вычитание"/>
                    <Button Content="," Style="{StaticResource NumberButtonStyle}" 
                            Click="Decimal_Click" ToolTip="Десятичный разделитель"/>
                </UniformGrid>

                
                <Grid Margin="0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="0" Style="{StaticResource NumberButtonStyle}" 
                            Margin="2" Height="45" Click="Number_Click" ToolTip="0"/>
                    <Button Grid.Column="1" Content="=" Style="{StaticResource EqualButtonStyle}" 
                            Margin="2" Height="45" Click="Equals_Click" ToolTip="Вычислить результат"/>
                    <Button Grid.Column="2" Content="+" Style="{StaticResource OperatorButtonStyle}" 
                            Margin="2" Height="45" Tag="Add" Click="Operator_Click" ToolTip="Сложение"/>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>